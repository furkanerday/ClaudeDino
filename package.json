{
  "name": "claudedino",
  "version": "0.1.0",
  "description": "A tiny dino runner game that takes over the dead space in Claude Code's terminal while the AI is processing.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claudedino": "dist/cli.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check:suppressions": "bash scripts/check-suppressions.sh",
    "check:all": "bash scripts/check-all.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.14.1",
    "@types/react": "^19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-unicorn": "^59.0.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "ink-use-stdout-dimensions": "^1.0.5",
    "react": "^19.2.5"
  }
}
